---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import JsonLd from '../components/seo/JsonLd.astro';
import '../styles/global.css';
import { SITE } from '../config/site';

interface BreadcrumbItem {
  name: string;
  path: string;
}

type JsonLdNode = Record<string, unknown>;

interface Props {
  title?: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: 'website' | 'article';
  publishedTime?: Date;
  modifiedTime?: Date;
  noindex?: boolean;
  jsonLd?: JsonLdNode | JsonLdNode[];
  breadcrumbs?: BreadcrumbItem[];
  bodyClass?: string;
}

const {
  title = SITE.name,
  description = SITE.description,
  image = SITE.defaultImage,
  imageAlt = title,
  type = 'website',
  publishedTime,
  modifiedTime,
  noindex = false,
  jsonLd,
  breadcrumbs = [],
  bodyClass = '',
} = Astro.props;

const siteUrl = Astro.site ?? new URL(SITE.url);
const canonicalURL = new URL(Astro.url.pathname, siteUrl);
const socialImage = new URL(image || SITE.defaultImage, siteUrl);
const fullTitle = title === SITE.name || title.includes(SITE.name)
  ? title
  : `${title}｜${SITE.shortName}`;
const robotsContent = noindex
  ? 'noindex,follow'
  : 'index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1';
const sameAs = [SITE.threads, SITE.instagram].filter(Boolean);

const organizationId = `${SITE.url}/#organization`;
const websiteId = `${SITE.url}/#website`;
const webpageId = `${canonicalURL.href}#webpage`;
const breadcrumbId = `${canonicalURL.href}#breadcrumb`;
const imageId = `${socialImage.href}#primaryimage`;

const globalGraph: JsonLdNode[] = [
  {
    '@type': 'Organization',
    '@id': organizationId,
    name: SITE.name,
    url: SITE.url,
    email: SITE.email,
    logo: {
      '@type': 'ImageObject',
      url: new URL(SITE.logo.src, siteUrl).href,
      width: SITE.logo.width,
      height: SITE.logo.height,
    },
    sameAs,
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    name: SITE.name,
    url: SITE.url,
    description: SITE.description,
    publisher: { '@id': organizationId },
    inLanguage: SITE.language,
  },
  {
    '@type': 'ImageObject',
    '@id': imageId,
    url: socialImage.href,
    contentUrl: socialImage.href,
    caption: imageAlt,
  },
  {
    '@type': 'WebPage',
    '@id': webpageId,
    url: canonicalURL.href,
    name: fullTitle,
    description,
    isPartOf: { '@id': websiteId },
    primaryImageOfPage: { '@id': imageId },
    inLanguage: SITE.language,
    ...(breadcrumbs.length >= 2 ? { breadcrumb: { '@id': breadcrumbId } } : {}),
  },
];

const breadcrumbGraph: JsonLdNode[] = breadcrumbs.length >= 2
  ? [{
      '@type': 'BreadcrumbList',
      '@id': breadcrumbId,
      itemListElement: breadcrumbs.map((item, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        name: item.name,
        item: new URL(item.path, siteUrl).href,
      })),
    }]
  : [];

const withoutContext = (node: JsonLdNode): JsonLdNode => {
  const { '@context': _context, ...rest } = node;
  return rest;
};

const pageGraph = (jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])
  .flatMap((node) => {
    const graph = node['@graph'];
    return Array.isArray(graph) ? graph as JsonLdNode[] : [node];
  })
  .map(withoutContext);

const structuredData = {
  '@context': 'https://schema.org',
  '@graph': [...globalGraph, ...breadcrumbGraph, ...pageGraph],
};
---
<!doctype html>
<html lang={SITE.language} id="top">
  <head>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.analyticsId}`}></script>
    <script is:inline define:vars={{ analyticsId: SITE.analyticsId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', analyticsId);
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="googlebot" content={robotsContent} />
    <meta name="theme-color" content="#fffdf9" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="generator" content={Astro.generator} />
    <script is:inline>window.addEventListener('beforeinstallprompt',(event)=>event.preventDefault());</script>

    <link rel="canonical" href={canonicalURL.href} />
    <link rel="alternate" hreflang={SITE.language} href={canonicalURL.href} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL.href} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" title={`${SITE.name} RSS`} href="/rss.xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/icon-192.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <meta property="og:locale" content={SITE.locale} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL.href} />
    <meta property="og:image" content={socialImage.href} />
    <meta property="og:image:alt" content={imageAlt} />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {modifiedTime && <meta property="article:modified_time" content={modifiedTime.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage.href} />
    <meta name="twitter:image:alt" content={imageAlt} />

    <title>{fullTitle}</title>
    <JsonLd data={structuredData} />
  </head>
  <body class:list={['site-body', bodyClass]}>
    <a class="skip-link" href="#main-content">跳到主要內容</a>
    <Header />
    <div class="site-content" id="main-content" tabindex="-1"><slot /></div>
    <Footer />
  </body>
</html>

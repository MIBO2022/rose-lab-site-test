---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/content/ArticleCard.astro';
import { getVisiblePosts } from '../../utils/content';

export async function getStaticPaths() {
  const posts = await getVisiblePosts();
  const categories = [...new Set(posts.map((post) => post.data.category))];
  return categories.map((category) => ({
    params: { category },
    props: { category, posts: posts.filter((post) => post.data.category === category) },
  }));
}

const { category, posts } = Astro.props;
---
<BaseLayout
  title={`${category}｜Rose Lab`}
  description={`瀏覽 Rose Lab 的「${category}」分類文章。`}
  breadcrumbs={[
    { name: '首頁', path: '/' },
    { name: '文章', path: '/blog/' },
    { name: category, path: Astro.url.pathname },
  ]}
>
  <main class="wrap listing-page taxonomy-page">
    <nav class="breadcrumbs" aria-label="麵包屑"><a href="/">首頁</a><span>›</span><a href="/blog/">文章</a><span>›</span><span>{category}</span></nav>
    <header class="page-header"><p class="eyebrow">CATEGORY</p><h1>{category}</h1><p>共 {posts.length} 篇文章</p></header>
    <div class="article-grid">
      {posts.map((post, index) => <ArticleCard post={post} eager={index === 0} />)}
    </div>
  </main>
</BaseLayout>

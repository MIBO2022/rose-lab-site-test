---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getVisiblePosts, postPath } from '../../utils/content';

export async function getStaticPaths() {
  const posts = await getVisiblePosts();
  const names = [...new Set(posts.map((post) => post.data.series).filter(Boolean))];
  return names.map((series) => ({
    params: { series },
    props: {
      series,
      posts: posts
        .filter((post) => post.data.series === series)
        .sort((a,b)=>(a.data.seriesOrder ?? 999)-(b.data.seriesOrder ?? 999)),
    },
  }));
}
const { series, posts } = Astro.props;
---
<BaseLayout
  title={`${series}系列文章｜Rose Lab`}
  description={`依照建議閱讀順序整理 Rose Lab 的${series}系列文章。`}
  breadcrumbs={[
    { name: '首頁', path: '/' },
    { name: '文章', path: '/blog/' },
    { name: series, path: Astro.url.pathname },
  ]}
>
  <main class="taxonomy-page wrap">
    <nav class="breadcrumbs" aria-label="麵包屑"><a href="/">首頁</a><span>›</span><a href="/blog/">文章</a><span>›</span><span>{series}</span></nav>
    <header class="taxonomy-head series-archive-head"><span>ROSE LAB SERIES</span><h1>{series}</h1><p>依照實際閱讀與執行順序整理，從第一篇開始看即可。</p></header>
    <ol class="series-archive-list">
      {posts.map((post,index)=>(
        <li>
          <a href={postPath(post)}>
            <span class="series-number">{String(index+1).padStart(2,'0')}</span>
            <div>{post.data.cover && <img src={post.data.cover} alt={post.data.coverAlt ?? post.data.title} loading="lazy" decoding="async"/>}</div>
            <section><small>{post.data.category}</small><h2>{post.data.title}</h2><p>{post.data.description}</p></section>
          </a>
        </li>
      ))}
    </ol>
  </main>
</BaseLayout>
